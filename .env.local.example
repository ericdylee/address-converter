# 행정안전부 도로명주소 영문 API 승인키
# 발급: https://business.juso.go.kr → 회원가입 → 오픈API → 영문주소 신청
JUSO_API_KEY=여기에_발급받은_승인키를_붙여넣으세요

# Google AdSense publisher ID (도메인 연결 + 승인 후 채워넣으세요)
# 형식: ca-pub-XXXXXXXXXXXXXXXX
# 비어 있으면 AdSense 스크립트가 로드되지 않습니다 (개발 환경 기본).
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# 사이트 기본 주소 (커스텀 도메인 연결 후 채워넣으세요)
# 형식: https://example.com  (끝에 / 없이)
# sitemap.xml·메타데이터·문의 이메일(contact@<도메인>)이 이 값을 기준으로 생성됩니다.
# 비어 있으면 현재 Vercel 주소로 폴백합니다.
NEXT_PUBLIC_SITE_URL=
